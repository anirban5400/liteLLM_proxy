# Safe defaults for local development. Override in `.env` for any real deployment.
LITELLM_PORT=4000
LITELLM_BIND_ADDRESS=127.0.0.1
LITELLM_IMAGE=ghcr.io/berriai/litellm:v1.83.7-stable

# Postgres (db service). Keep POSTGRES_* and DATABASE_URL in sync if you change the password.
# For production, set POSTGRES_PASSWORD and DATABASE_URL in `.env`.
POSTGRES_USER=litellm
POSTGRES_PASSWORD=litellm_local_dev
POSTGRES_DB=litellm
DATABASE_URL=postgresql://litellm:litellm_local_dev@db:5432/litellm

# LiteLLM admin UI — must start with sk-
LITELLM_MASTER_KEY=sk-litellm-change-me

# Production reverse proxy defaults. Override in `.env` if needed.
PUBLIC_DOMAIN=
CADDY_IMAGE=caddy:2.8.4
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
