# Copy to .env (gitignored) and fill in:
#   cp .env.example .env
#
# Values override env/compose.defaults.env.
# For production on a Droplet, set PUBLIC_DOMAIN, POSTGRES_PASSWORD, and DATABASE_URL.

# Local mode defaults
# LITELLM_PORT=4000
# LITELLM_BIND_ADDRESS=127.0.0.1

# Production mode
PUBLIC_DOMAIN=llm.example.com
POSTGRES_PASSWORD=change-this-to-a-long-random-string
