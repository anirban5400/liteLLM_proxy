# Copy to .env (gitignored) and fill in:
#   cp .env.example .env
#
# Values override env/compose.defaults.env.
# Use ONE mode at a time:
# 1. Production with a domain: use `./scripts/litellm start-prod`
# 2. Public IP / temporary HTTP mode: use `./scripts/litellm start`

# Public IP / temporary HTTP mode only
# Uncomment these only if you want plain HTTP on the Droplet IP with `./scripts/litellm start`
# LITELLM_PORT=4000
# LITELLM_BIND_ADDRESS=0.0.0.0

# Production mode with a real domain and HTTPS
# Do not set LITELLM_BIND_ADDRESS for `start-prod`; Caddy is the public entrypoint on 80/443.
PUBLIC_DOMAIN=llm.example.com
POSTGRES_PASSWORD=change-this-to-a-long-random-string
DATABASE_URL=postgresql://litellm:change-this-to-a-long-random-string@db:5432/litellm
LITELLM_MASTER_KEY=sk-litellm-change-me

# Active model example
ALIAS_NAME_1=kimi-k2.5-cloud-1
MODEL_NAME_1=ollama/kimi-k2.5:cloud
API_BASE_1=https://ollama.com
API_KEY_1=

